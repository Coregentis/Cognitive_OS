{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.coregentis.dev/cgos/v0/objects/confirm-gate.schema.json",
  "title": "Coregentis Confirm Gate",
  "description": "First-class Coregentis governance object representing a runtime-bound confirm gate rooted in MPLP confirm semantics. This preserves shallow protocol reconstructability without implementing the full binding matrix.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/properties/schema_version"
    },
    "object_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/properties/object_id"
    },
    "object_type": {
      "const": "confirm-gate"
    },
    "authority_class": {
      "const": "runtime_bound"
    },
    "primary_layer": {
      "const": "cognitive_runtime_core"
    },
    "status": {
      "type": "string",
      "enum": [
        "not_required",
        "pending",
        "approved",
        "rejected",
        "bypassed",
        "escalated"
      ]
    },
    "protocol_binding_ref": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/properties/protocol_binding_ref"
    },
    "temporal": {
      "$ref": "../base/temporal-record.schema.json"
    },
    "mutation": {
      "$ref": "../base/mutation-record.schema.json"
    },
    "lineage": {
      "$ref": "../base/lineage-record.schema.json"
    },
    "governance": {
      "$ref": "../base/governance-record.schema.json"
    },
    "project_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
    },
    "target_object_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
    },
    "confirm_kind": {
      "type": "string",
      "enum": [
        "approval",
        "review",
        "escalation"
      ]
    },
    "requested_by_ref": {
      "type": "string"
    },
    "decision_due_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "required": [
    "object_id",
    "object_type",
    "authority_class",
    "primary_layer",
    "status",
    "temporal",
    "mutation",
    "lineage",
    "governance",
    "project_id",
    "target_object_id",
    "confirm_kind"
  ],
  "x-coregentis-meta": {
    "schema_role": "object-schema",
    "phase": "mother-runtime-foundation",
    "version_stream": "v0",
    "authority_order_preserved": true,
    "governing_doc": "CGOS-SCHEMA-GOVERNANCE-BASELINE-v0.1",
    "object_family": "governance"
  }
}
