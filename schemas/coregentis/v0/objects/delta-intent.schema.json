{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.coregentis.dev/cgos/v0/objects/delta-intent.schema.json",
  "title": "Coregentis Delta Intent",
  "description": "First-class Coregentis delta intent object. This is a runtime-bound change object representing governed modification against an existing intent state.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/properties/schema_version"
    },
    "object_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/properties/object_id"
    },
    "object_type": {
      "const": "delta-intent"
    },
    "authority_class": {
      "const": "runtime_bound"
    },
    "primary_layer": {
      "const": "cognitive_runtime_core"
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "accepted",
        "rejected",
        "superseded",
        "reconciled"
      ]
    },
    "protocol_binding_ref": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/properties/protocol_binding_ref"
    },
    "temporal": {
      "$ref": "../base/temporal-record.schema.json"
    },
    "mutation": {
      "$ref": "../base/mutation-record.schema.json"
    },
    "lineage": {
      "$ref": "../base/lineage-record.schema.json"
    },
    "governance": {
      "$ref": "../base/governance-record.schema.json"
    },
    "project_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
    },
    "base_intent_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
    },
    "delta_kind": {
      "type": "string",
      "enum": [
        "refine",
        "replace",
        "redirect",
        "cancel"
      ]
    },
    "change_summary": {
      "type": "string",
      "minLength": 1
    },
    "source_input_ref": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "object_id",
    "object_type",
    "authority_class",
    "primary_layer",
    "status",
    "temporal",
    "mutation",
    "lineage",
    "governance",
    "project_id",
    "base_intent_id",
    "delta_kind",
    "change_summary",
    "source_input_ref"
  ],
  "x-coregentis-meta": {
    "schema_role": "object-schema",
    "phase": "mother-runtime-foundation",
    "version_stream": "v0",
    "authority_order_preserved": true,
    "governing_doc": "CGOS-SCHEMA-GOVERNANCE-BASELINE-v0.1",
    "object_family": "entry"
  }
}
