{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.coregentis.dev/cgos/v0/objects/intent.schema.json",
  "title": "Coregentis Intent",
  "description": "First-class Coregentis intent object. This is a runtime-bound object that governs what enters the cognitive runtime and preserves reconstructable linkage to protocol-relevant intent semantics when needed.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/properties/schema_version"
    },
    "object_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/properties/object_id"
    },
    "object_type": {
      "const": "intent"
    },
    "authority_class": {
      "const": "runtime_bound"
    },
    "primary_layer": {
      "const": "cognitive_runtime_core"
    },
    "status": {
      "type": "string",
      "enum": [
        "formed",
        "active",
        "resolved",
        "superseded",
        "blocked"
      ]
    },
    "protocol_binding_ref": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/properties/protocol_binding_ref"
    },
    "temporal": {
      "$ref": "../base/temporal-record.schema.json"
    },
    "mutation": {
      "$ref": "../base/mutation-record.schema.json"
    },
    "lineage": {
      "$ref": "../base/lineage-record.schema.json"
    },
    "governance": {
      "$ref": "../base/governance-record.schema.json"
    },
    "project_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
    },
    "intent_kind": {
      "type": "string",
      "enum": [
        "task",
        "query",
        "review",
        "correction",
        "planning",
        "change"
      ]
    },
    "intent_summary": {
      "type": "string",
      "minLength": 1
    },
    "source_input_ref": {
      "type": "string",
      "minLength": 1
    },
    "ambiguity_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "clarification_required": {
      "type": "boolean"
    }
  },
  "required": [
    "object_id",
    "object_type",
    "authority_class",
    "primary_layer",
    "status",
    "temporal",
    "mutation",
    "lineage",
    "governance",
    "project_id",
    "intent_kind",
    "intent_summary",
    "source_input_ref"
  ],
  "x-coregentis-meta": {
    "schema_role": "object-schema",
    "phase": "mother-runtime-foundation",
    "version_stream": "v0",
    "authority_order_preserved": true,
    "governing_doc": "CGOS-SCHEMA-GOVERNANCE-BASELINE-v0.1",
    "object_family": "entry"
  }
}
