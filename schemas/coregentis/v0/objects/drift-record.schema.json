{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.coregentis.dev/cgos/v0/objects/drift-record.schema.json",
  "title": "Coregentis Drift Record",
  "description": "First-class Coregentis governance and evidence object representing detected divergence from prior expectation or retained truth. This is a Coregentis-private runtime object.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/properties/schema_version"
    },
    "object_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/properties/object_id"
    },
    "object_type": {
      "const": "drift-record"
    },
    "authority_class": {
      "const": "coregentis_private_runtime"
    },
    "primary_layer": {
      "const": "cognitive_runtime_core"
    },
    "status": {
      "type": "string",
      "enum": [
        "detected",
        "reviewed",
        "resolved",
        "dismissed"
      ]
    },
    "temporal": {
      "$ref": "../base/temporal-record.schema.json"
    },
    "mutation": {
      "$ref": "../base/mutation-record.schema.json"
    },
    "lineage": {
      "$ref": "../base/lineage-record.schema.json"
    },
    "governance": {
      "$ref": "../base/governance-record.schema.json"
    },
    "project_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
    },
    "drift_kind": {
      "type": "string",
      "enum": [
        "intent_drift",
        "fact_drift",
        "plan_drift",
        "execution_drift"
      ]
    },
    "drift_summary": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "baseline_object_refs": {
      "type": "array",
      "items": {
        "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
      },
      "uniqueItems": true
    },
    "observed_object_refs": {
      "type": "array",
      "items": {
        "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "required": [
    "object_id",
    "object_type",
    "authority_class",
    "primary_layer",
    "status",
    "temporal",
    "mutation",
    "lineage",
    "governance",
    "project_id",
    "drift_kind",
    "drift_summary",
    "severity",
    "observed_object_refs"
  ],
  "x-coregentis-meta": {
    "schema_role": "object-schema",
    "phase": "mother-runtime-foundation",
    "version_stream": "v0",
    "authority_order_preserved": true,
    "governing_doc": "CGOS-SCHEMA-GOVERNANCE-BASELINE-v0.1",
    "object_family": "governance"
  }
}
