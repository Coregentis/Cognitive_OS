{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.coregentis.dev/cgos/v0/objects/learning-candidate.schema.json",
  "title": "Coregentis Learning Candidate",
  "description": "First-class Coregentis learning object representing governed candidate experience before consolidation. This is a Coregentis-private runtime object.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/properties/schema_version"
    },
    "object_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/properties/object_id"
    },
    "object_type": {
      "const": "learning-candidate"
    },
    "authority_class": {
      "const": "coregentis_private_runtime"
    },
    "primary_layer": {
      "const": "cognitive_runtime_core"
    },
    "status": {
      "type": "string",
      "enum": [
        "captured",
        "scored",
        "promoted",
        "deferred",
        "discarded"
      ]
    },
    "temporal": {
      "$ref": "../base/temporal-record.schema.json"
    },
    "mutation": {
      "$ref": "../base/mutation-record.schema.json"
    },
    "lineage": {
      "$ref": "../base/lineage-record.schema.json"
    },
    "governance": {
      "$ref": "../base/governance-record.schema.json"
    },
    "project_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
    },
    "candidate_kind": {
      "type": "string",
      "enum": [
        "success_pattern",
        "failure_pattern",
        "reuse_pattern",
        "policy_suggestion"
      ]
    },
    "candidate_summary": {
      "type": "string",
      "minLength": 1
    },
    "source_episode_refs": {
      "type": "array",
      "items": {
        "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "source_evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "score_label": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    }
  },
  "required": [
    "object_id",
    "object_type",
    "authority_class",
    "primary_layer",
    "status",
    "temporal",
    "mutation",
    "lineage",
    "governance",
    "project_id",
    "candidate_kind",
    "candidate_summary",
    "source_episode_refs"
  ],
  "x-coregentis-meta": {
    "schema_role": "object-schema",
    "phase": "mother-runtime-foundation",
    "version_stream": "v0",
    "authority_order_preserved": true,
    "governing_doc": "CGOS-SCHEMA-GOVERNANCE-BASELINE-v0.1",
    "object_family": "learning"
  }
}
