{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.coregentis.dev/cgos/v0/objects/learning-candidate.schema.json",
  "title": "Coregentis Learning Candidate",
  "description": "First-class Coregentis learning object representing governed candidate experience before consolidation. This is a Coregentis-private runtime object.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/properties/schema_version"
    },
    "object_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/properties/object_id"
    },
    "object_type": {
      "const": "learning-candidate"
    },
    "authority_class": {
      "const": "coregentis_private_runtime"
    },
    "primary_layer": {
      "const": "cognitive_runtime_core"
    },
    "status": {
      "type": "string",
      "enum": [
        "captured",
        "scored",
        "promoted",
        "deferred",
        "discarded"
      ]
    },
    "temporal": {
      "$ref": "../base/temporal-record.schema.json"
    },
    "mutation": {
      "$ref": "../base/mutation-record.schema.json"
    },
    "lineage": {
      "$ref": "../base/lineage-record.schema.json"
    },
    "governance": {
      "$ref": "../base/governance-record.schema.json"
    },
    "project_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
    },
    "candidate_kind": {
      "type": "string",
      "enum": [
        "success_pattern",
        "failure_pattern",
        "reuse_pattern",
        "policy_suggestion"
      ]
    },
    "candidate_summary": {
      "type": "string",
      "minLength": 1
    },
    "candidate_hint_type": {
      "type": "string",
      "enum": [
        "reuse_pattern_candidate",
        "failure_pattern_candidate",
        "policy_suggestion_candidate",
        "continuity_pattern_candidate"
      ]
    },
    "source_episode_refs": {
      "type": "array",
      "items": {
        "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "source_object_refs": {
      "type": "array",
      "items": {
        "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
      },
      "uniqueItems": true
    },
    "source_evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "source_relation_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "activation_outcome": {
      "type": "string",
      "enum": [
        "activate",
        "confirm_required",
        "suppressed",
        "escalate"
      ]
    },
    "continuity_anchor_ref": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "impacted_object_refs": {
      "type": "array",
      "items": {
        "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
      },
      "uniqueItems": true
    },
    "drift_record_refs": {
      "type": "array",
      "items": {
        "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
      },
      "uniqueItems": true
    },
    "conflict_case_refs": {
      "type": "array",
      "items": {
        "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
      },
      "uniqueItems": true
    },
    "future_protocol_sample_family": {
      "type": "string",
      "enum": [
        "intent_resolution",
        "delta_impact",
        "pipeline_outcome",
        "confirm_decision",
        "graph_evolution"
      ]
    },
    "future_protocol_export_eligibility": {
      "type": "string",
      "enum": [
        "not_eligible",
        "derived_only_future_governance"
      ]
    },
    "suggestion_only": {
      "type": "boolean"
    },
    "policy_mutation_applied": {
      "type": "boolean"
    },
    "semantic_promotion_applied": {
      "type": "boolean"
    },
    "linked_promotion_record_refs": {
      "type": "array",
      "items": {
        "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
      },
      "uniqueItems": true
    },
    "score_label": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    }
  },
  "required": [
    "object_id",
    "object_type",
    "authority_class",
    "primary_layer",
    "status",
    "temporal",
    "mutation",
    "lineage",
    "governance",
    "project_id",
    "candidate_kind",
    "candidate_summary",
    "source_episode_refs"
  ],
  "x-coregentis-meta": {
    "schema_role": "object-schema",
    "phase": "mother-runtime-foundation",
    "version_stream": "v0",
    "authority_order_preserved": true,
    "governing_doc": "CGOS-SCHEMA-GOVERNANCE-BASELINE-v0.1",
    "object_family": "learning"
  }
}
