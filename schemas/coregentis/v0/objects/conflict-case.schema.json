{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.coregentis.dev/cgos/v0/objects/conflict-case.schema.json",
  "title": "Coregentis Conflict Case",
  "description": "First-class Coregentis governance and evidence object representing a typed runtime conflict. This is a Coregentis-private runtime object.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/properties/schema_version"
    },
    "object_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/properties/object_id"
    },
    "object_type": {
      "const": "conflict-case"
    },
    "authority_class": {
      "const": "coregentis_private_runtime"
    },
    "primary_layer": {
      "const": "cognitive_runtime_core"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "classified",
        "resolved",
        "branched",
        "escalated",
        "dismissed"
      ]
    },
    "temporal": {
      "$ref": "../base/temporal-record.schema.json"
    },
    "mutation": {
      "$ref": "../base/mutation-record.schema.json"
    },
    "lineage": {
      "$ref": "../base/lineage-record.schema.json"
    },
    "governance": {
      "$ref": "../base/governance-record.schema.json"
    },
    "project_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
    },
    "conflict_kind": {
      "type": "string",
      "enum": [
        "intent_conflict",
        "fact_conflict",
        "plan_conflict",
        "authority_conflict",
        "policy_conflict",
        "execution_conflict"
      ]
    },
    "conflict_summary": {
      "type": "string",
      "minLength": 1
    },
    "object_refs": {
      "type": "array",
      "items": {
        "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "proposed_resolution": {
      "type": "string",
      "enum": [
        "override",
        "merge",
        "coexist",
        "branch",
        "escalate"
      ]
    }
  },
  "required": [
    "object_id",
    "object_type",
    "authority_class",
    "primary_layer",
    "status",
    "temporal",
    "mutation",
    "lineage",
    "governance",
    "project_id",
    "conflict_kind",
    "conflict_summary",
    "object_refs"
  ],
  "x-coregentis-meta": {
    "schema_role": "object-schema",
    "phase": "mother-runtime-foundation",
    "version_stream": "v0",
    "authority_order_preserved": true,
    "governing_doc": "CGOS-SCHEMA-GOVERNANCE-BASELINE-v0.1",
    "object_family": "governance"
  }
}
