{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.coregentis.dev/cgos/v0/workforce/approval-request-record.schema.json",
  "title": "Coregentis Approval Request Record",
  "description": "Runtime-private approval-request-like gate record for one bounded cell runtime scope. This is an internal governance precondition and not MPLP law.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/properties/schema_version"
    },
    "object_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/properties/object_id"
    },
    "object_type": {
      "const": "approval-request-record"
    },
    "authority_class": {
      "const": "coregentis_private_runtime"
    },
    "primary_layer": {
      "const": "organization_runtime_layer"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "resolved",
        "withdrawn",
        "archived"
      ]
    },
    "temporal": {
      "$ref": "../base/temporal-record.schema.json"
    },
    "mutation": {
      "$ref": "../base/mutation-record.schema.json"
    },
    "lineage": {
      "$ref": "../base/lineage-record.schema.json"
    },
    "governance": {
      "$ref": "../base/governance-record.schema.json"
    },
    "project_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
    },
    "cell_runtime_scope_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
    },
    "objective_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
    },
    "management_record_kind": {
      "const": "approval_request"
    },
    "request_kind": {
      "type": "string",
      "enum": [
        "approval",
        "escalation"
      ]
    },
    "request_summary": {
      "type": "string",
      "minLength": 1
    },
    "requested_decision": {
      "type": "string",
      "minLength": 1
    },
    "urgency": {
      "type": "string",
      "enum": [
        "normal",
        "high",
        "critical"
      ]
    }
  },
  "required": [
    "object_id",
    "object_type",
    "authority_class",
    "primary_layer",
    "status",
    "temporal",
    "mutation",
    "lineage",
    "governance",
    "project_id",
    "cell_runtime_scope_id",
    "management_record_kind",
    "request_kind",
    "request_summary",
    "requested_decision",
    "urgency"
  ],
  "x-coregentis-meta": {
    "schema_role": "object-schema",
    "phase": "mother-runtime-workforce-v0.4-preconditions",
    "version_stream": "v0",
    "authority_order_preserved": true,
    "governing_doc": "CGOS-MANAGEMENT-OBJECT-FAMILY-DRAFT-v0.1",
    "object_family": "governance"
  }
}
