{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.coregentis.dev/cgos/v0/workforce/delivery-return-record.schema.json",
  "title": "Coregentis Delivery Return Record",
  "description": "Runtime-private delivery-return-like record for one bounded cell runtime scope. This captures internal runtime-precondition result shape only and is not a protocol export surface.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/properties/schema_version"
    },
    "object_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/properties/object_id"
    },
    "object_type": {
      "const": "delivery-return-record"
    },
    "authority_class": {
      "const": "coregentis_private_runtime"
    },
    "primary_layer": {
      "const": "organization_runtime_layer"
    },
    "status": {
      "type": "string",
      "enum": [
        "in_progress",
        "ready_for_review",
        "blocked",
        "returned",
        "archived"
      ]
    },
    "temporal": {
      "$ref": "../base/temporal-record.schema.json"
    },
    "mutation": {
      "$ref": "../base/mutation-record.schema.json"
    },
    "lineage": {
      "$ref": "../base/lineage-record.schema.json"
    },
    "governance": {
      "$ref": "../base/governance-record.schema.json"
    },
    "project_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
    },
    "cell_runtime_scope_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
    },
    "objective_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
    },
    "management_record_kind": {
      "const": "delivery_return"
    },
    "completed_summary": {
      "type": "string"
    },
    "blocked_summary": {
      "type": "string"
    },
    "next_directive_needed": {
      "type": "boolean"
    },
    "requested_follow_up": {
      "type": "string"
    }
  },
  "required": [
    "object_id",
    "object_type",
    "authority_class",
    "primary_layer",
    "status",
    "temporal",
    "mutation",
    "lineage",
    "governance",
    "project_id",
    "cell_runtime_scope_id",
    "management_record_kind",
    "completed_summary",
    "blocked_summary",
    "next_directive_needed"
  ],
  "x-coregentis-meta": {
    "schema_role": "object-schema",
    "phase": "mother-runtime-workforce-v0.4-preconditions",
    "version_stream": "v0",
    "authority_order_preserved": true,
    "governing_doc": "CGOS-MANAGEMENT-OBJECT-FAMILY-DRAFT-v0.1",
    "object_family": "governance"
  }
}
