{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.coregentis.dev/cgos/v0/workforce/objective.schema.json",
  "title": "Coregentis Objective",
  "description": "Neutral organization-runtime objective object used to anchor longer-horizon target state and bounded progress summaries.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/properties/schema_version"
    },
    "object_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/properties/object_id"
    },
    "object_type": {
      "const": "objective"
    },
    "authority_class": {
      "const": "coregentis_private_runtime"
    },
    "primary_layer": {
      "const": "organization_runtime_layer"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "blocked",
        "completed",
        "archived"
      ]
    },
    "temporal": {
      "$ref": "../base/temporal-record.schema.json"
    },
    "mutation": {
      "$ref": "../base/mutation-record.schema.json"
    },
    "lineage": {
      "$ref": "../base/lineage-record.schema.json"
    },
    "governance": {
      "$ref": "../base/governance-record.schema.json"
    },
    "project_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
    },
    "group_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
    },
    "owner_worker_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
    },
    "objective_summary": {
      "type": "string",
      "minLength": 1
    },
    "progress_summary": {
      "type": "string"
    },
    "success_signals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "work_item_ids": {
      "type": "array",
      "items": {
        "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
      },
      "uniqueItems": true
    },
    "target_due_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "object_id",
    "object_type",
    "authority_class",
    "primary_layer",
    "status",
    "temporal",
    "mutation",
    "lineage",
    "governance",
    "project_id",
    "objective_summary"
  ],
  "x-coregentis-meta": {
    "schema_role": "object-schema",
    "phase": "mother-runtime-workforce-p0a",
    "version_stream": "v0",
    "authority_order_preserved": true,
    "governing_doc": "CGOS-IMPLEMENTATION-EXECUTION-PLAN-v0.1",
    "object_family": "organization"
  }
}
