{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.coregentis.dev/cgos/v0/workforce/review-cycle.schema.json",
  "title": "Coregentis Review Cycle",
  "description": "Neutral organization-runtime review cadence object for periodic assessment of objectives, workers, and runtime progress.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/properties/schema_version"
    },
    "object_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/properties/object_id"
    },
    "object_type": {
      "const": "review-cycle"
    },
    "authority_class": {
      "const": "coregentis_private_runtime"
    },
    "primary_layer": {
      "const": "organization_runtime_layer"
    },
    "status": {
      "type": "string",
      "enum": [
        "scheduled",
        "active",
        "closed",
        "archived"
      ]
    },
    "temporal": {
      "$ref": "../base/temporal-record.schema.json"
    },
    "mutation": {
      "$ref": "../base/mutation-record.schema.json"
    },
    "lineage": {
      "$ref": "../base/lineage-record.schema.json"
    },
    "governance": {
      "$ref": "../base/governance-record.schema.json"
    },
    "project_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
    },
    "group_id": {
      "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
    },
    "cadence_kind": {
      "type": "string",
      "enum": [
        "daily",
        "weekly",
        "milestone",
        "on_demand"
      ]
    },
    "review_scope_summary": {
      "type": "string",
      "minLength": 1
    },
    "objective_ids": {
      "type": "array",
      "items": {
        "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
      },
      "uniqueItems": true
    },
    "participant_worker_ids": {
      "type": "array",
      "items": {
        "$ref": "../base/cognitive-object-envelope.schema.json#/$defs/coregentis_identifier"
      },
      "uniqueItems": true
    },
    "next_review_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_review_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "object_id",
    "object_type",
    "authority_class",
    "primary_layer",
    "status",
    "temporal",
    "mutation",
    "lineage",
    "governance",
    "project_id",
    "cadence_kind",
    "review_scope_summary",
    "next_review_at"
  ],
  "x-coregentis-meta": {
    "schema_role": "object-schema",
    "phase": "mother-runtime-workforce-p0a",
    "version_stream": "v0",
    "authority_order_preserved": true,
    "governing_doc": "CGOS-IMPLEMENTATION-EXECUTION-PLAN-v0.1",
    "object_family": "governance"
  }
}
